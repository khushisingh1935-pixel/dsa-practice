//select the minimum and swap 
#include<iostream>
using namespace std;
void selectionSort(int arr[], int n){
    for(int i = 0; i<=n-2; i++){
        int mini = i;
        for(int j = i; j<=n-2; j++){
            if(arr[j]<arr[mini]){
                mini = j;
            }
        }
        swap(arr[mini], arr[i]) 
    }
}