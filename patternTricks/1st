//for the outer loop, count the number of lines
//for the inner loop, count the number of columns
//print the *** inside the inner for loop 
#include<bits/stdc++.h>
using namespace std;
void print1(int n){
    for(int i = 0; i<n; i++){
        for(int j=0; j<n; j++){
            cout<<"*";
        }
        cout<<endl;
    }
}
    int main(){
        int n; 
        cin>>n;
        print(n);
        return 0;
    }
