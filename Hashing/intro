//hashing : pre storing and fetching values in a data structure using a key
#include<iostream>
using namespace std;
int main(){
    int n;
    cin>>n; //size of array
    int arr[n];
    for(int i = 0; i<n; i++){
        cin>>arr[i];
    }
    //precompute
    int hash [100] = {0}; //hash array to store the frequency of elements in the input array
    for(int i = 0; i<n; i++){
        hash[arr[i]]++; //increment the frequency of the element in the hash array
    }
    int q;
    cin>>q; //number of queries
    while(q--){
        int number;
        cin>>number; //number to be searched in the input array
        cout<<hash[number]<<endl; //print the frequency of the number in the input array
    }
    return 0;
}
//CHARACTER HASHING
#include<iostream>
using namespace std;
int main(){
    string s;
    cin>>s; //input string
    int hash[256] = {0}; //hash array to store the frequency of characters in the input string
    for(int i = 0; i<s.length(); i++){
        hash[s[i]]++; //increment the frequency of the character in the hash array
    }
    int q;
    cin>>q; //number of queries
    while(q--){
        char c;
        cin>>c; //character to be searched in the input string
        cout<<hash[c]<<endl; //print the frequency of the character in the input string
    }
    return 0;
}