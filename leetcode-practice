vector<int> sortArray(vector<int>& nums){
    for(int i = 0; i<nums.size(); i++){
        for(int j = 1; j<nums.size(); j++){
            if (nums[j] < nums[i] && i < j){
                swap(nums[j], nums[i]);
            }
        }
    }
    return nums;
}
