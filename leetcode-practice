//count the digits that divide the number 
#include<iostream>
using namespace std;
int countDigits(int num){
    int original = num; //store a copy 
    int count = 0;
    while(num > 0){
        int digit = num%10; //extract last digit
        if(digit != 0 && original % digit === 0){
            count++;
        }
            num = num / 10;
    }
    return count;
}
