//MERGE SORTED ARRAY 
class Solution {
public:
    void merge(vector<int>& nums1, int m, vector<int>& nums2, int n) {

        for(int i = 0; i < n; i++)
        {
            nums1[m + i] = nums2[i];
        }

        for(int i = 0; i < m + n; i++)
        {
            for(int j = i + 1; j < m + n; j++)
            {
                if(nums1[j] < nums1[i])
                {
                    swap(nums1[i], nums1[j]);
                }
            }
        }
    }
};
