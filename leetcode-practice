//count the digits that divide the number 
#include<iostream>
using namespace std;
int countDigits(int num){
    int original = num; //store a copy 
    int count = 0;
    while(num > 0){
        int digit = num%10; //extract last digit
        if(digit != 0 && original % digit === 0){
            count++;
        }
            num = num / 10;
    }
    return count;
}
// reverse an integer
#include<iostream>
using namespace std;
int reverse(int x){
    int new = 0
    while(x>0){
        int lastDigit = x%10;
        new = new + lastDigit;
        x = x/10;
    }
    return x;
}
