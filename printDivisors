#include<bits/stdc++.h>
using namespace std;
void printDivisor(int n){
    for(int i=1; i<=n; i++){
        if(n%i==0){
            cout<<i<<" ";
        }
    }
}
    int main(){
        int n;
        cin>>n;
        printDivisor(n);
        return 0; 
    }
    //^^ time complexity is O(n) because we are iterating from 1 to n and checking if it is a divisor or not.
