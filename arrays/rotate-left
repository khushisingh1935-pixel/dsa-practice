//ROTATE ARRAY TO LEFT BY 1 
//DONT USE EXTRA ARRAY 
#include<iostream>
using namespace std;
int main(){
    int n;
    cin>>n;
    int arr[n];
    for(int i = 0; i<n; i++){
        cin>>arr[i];
    }
    int temp = arr[0]; //store first element 
    for(int i = 1; i<n; i++){
        arr[i-1] = arr[i]; //shift elements to left
    }
    arr[n-1] = temp; //put first element at the end
    //print the rotated array
    for(int i = 0; i<n; i++){
        cout<<arr[i]<<" ";
    }
}
//ROTATE BY D PLACES 
#include<iostream>
using namespace std;
int main(){
    int n, d;
    cin>>n>>d;
    int arr[n];
    for(int i = 0; i<n; i++){   
        cin>>arr[i];
    }
    d = d % n; //if d is greater than n 
    //store first d elements 
    int temp[d];
    for(int i = 0; i<d; i++){
        temp[i] = arr[i];
    }
    //shift the rest of the elements to left
    for(int i = d; i<n; i++){
        arr[i-d] = arr[i];
    }
    //put the stored elements at the end
    for(int i = 0; i<d; i++){
        arr[n - d + i] = temp[i];
    }
    //print the rotated array
    for(int i = 0; i<n; i++){
        cout<<arr[i]<<" ";
    }
}