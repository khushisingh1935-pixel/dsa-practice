#include<iostream>
#include<climits>
using namespace std;
int secondLargest(int arr[], int n){
    int largest = INT_MIN;
    int secondLargest = INT_MIN;
    for(int i = 0; i<n; i++){
        if(arr[i] > largest){
            secondLargest = largest;
            largest = arr[i];
        }
    }else if(arr[i] > secondLargest && arr[i] != largest){
        secondLargest = arr[i];
    }
return secondLargest;
}
int main(){
    int n; 
    cin>>n;
    int arr[n];
    for(int i = 0; i<n; i++){
        cin>>arr[i];
    }
    secondLargest(arr, n);
}