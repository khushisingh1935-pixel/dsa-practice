//when a function keeps on calling itself, until a condition (called base condition) is met, is called recursion. 
//if there is no base condition, the function will keep calling itself, causing a stack overflow, which gives a segmentation error.
//print 1 to n using recusrion 
#include<Iostream>
using namespace std;
void printNumbers(int n){
    if(n==0) return; //base condition
    printNumbers(n-1); //recursive call
    cout<<n<<" "; //print the number after the recursive call, so that it prints in increasing order.
}
int main(){
    int n;
    cin>>n;
    printNumbers(n);
    return 0;
}
//print 1 to n linearly using backtarcking 
#include<iostream>
using namespace std;
void print(int n){
    if(n<1) return;
    print(n-1);
    cout<<n<<" ";
}
int main(){
    int n;
    cin>>n;
    print(n);
    return 0;
}
//print n to 1 using backtracking
void print(int i, int n){
    if(i>n) return;
    cout<<i<<" ";
    print(i+1, n);
}
int main(){
    int n;
    cin>>n;
    print(1, n);
    return 0;
}